#include "../include/lime/@proxy_NAME@.hpp"

#include <lime/lib.hpp>

#define LIME_MAP_EXPORTS(TRANSFORMER) @MAP_EXPORTS@

std::uintptr_t originals[@EXPORT_COUNT@] = {};

namespace lime::@proxy_NAME@
{
    bool init(const std::filesystem::path &path)
    {
        auto original = lime::lib::load(path);

        if (!original.has_value())
        {
            return false;
        }

#define LIME_LOAD_ORIGINAL(index, name) originals[(index) - 1] = original->symbol(name).value();
        LIME_MAP_EXPORTS(LIME_LOAD_ORIGINAL)

        return true;
    }
}

#define LIME_EXPORT_FUNC(index, name)                                                                                                      \
    extern "C" __attribute__((naked, stdcall)) void LIME_PROXY_EXPORT_@proxy_NAME@_##index()                                                            \
    {                                                                                                                                      \
        asm volatile("jmp *%0" : : "r"(originals[(index) - 1]));                                                                           \
    }

LIME_MAP_EXPORTS(LIME_EXPORT_FUNC)
